{
  "name": "@tab10/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --dir src --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --dir src **/*.integration.test.ts",
    "test:load": "vitest run src/load.integration.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/sensible": "^6.0.3",
    "@node-rs/argon2": "^2.0.2",
    "@tab10/shared": "workspace:*",
    "@tab10/test-utils": "workspace:*",
    "drizzle-orm": "^0.39.3",
    "fastify": "^5.2.1",
    "nanoid": "^5.1.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^3.0.5"
  }
}
