{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && corepack enable && corepack prepare pnpm@9.15.0 --activate && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @tab10/web build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_RENDER_SERVICE.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://YOUR_RENDER_SERVICE.onrender.com/health"
    }
  ]
}
