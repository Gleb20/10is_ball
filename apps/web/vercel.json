{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && corepack enable && corepack prepare pnpm@9.15.0 --activate && pnpm install --frozen-lockfile --prod=false --filter \"@tab10/web...\"",
  "buildCommand": "cd ../.. && pnpm --filter @tab10/shared build && pnpm --filter @tab10/web build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://one0is-ball.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://one0is-ball.onrender.com/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
