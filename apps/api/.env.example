# Copy to apps/api/.env for local postgres (do not commit secrets)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
# Comma-separated browser origins allowed when calling API directly
# WEB_ORIGIN=http://localhost:5173,https://your-app.vercel.app
# COOKIE_SAME_SITE=none
SEED_ADMIN=1
# SEED_ADMIN_EMAIL=admin@tab10.local
# SEED_ADMIN_PASSWORD=AdminPass1!
# MIGRATE_ON_BOOT=0
